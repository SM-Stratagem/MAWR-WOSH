{
  "$meta": {
    "name": "WOSH",
    "version": "1.0.0",
    "direction": "Marine + Brutalist · Hero price-led",
    "tagline": "Premium car wash, at your door — without the theatre.",
    "updated": "2026-05-11"
  },
  "color": {
    "surface": {
      "bg":      { "value": "#dfe9e3", "use": "Page background. Cool pale celadon." },
      "bg-soft": { "value": "#d4e0d8", "use": "Card / chip background." },
      "bg-deep": { "value": "#c1d2c7", "use": "Pressed / hovered surface." },
      "paper":   { "value": "#f3f7f4", "use": "Sheets, modals, elevated layer." }
    },
    "ink": {
      "ink":       { "value": "#0e2236", "use": "Primary text. Also primary fill for buttons & emphasis." },
      "ink-soft":  { "value": "#4a5e6f", "use": "Secondary text." },
      "ink-dim":   { "value": "#7d8d99", "use": "Tertiary text, placeholders." },
      "line":      { "value": "#b2c3b8", "use": "Default 1px border / divider." },
      "line-soft": { "value": "#c8d4cc", "use": "Subtle divider, dotted rules." }
    },
    "accent": {
      "accent":      { "value": "#1976ff", "use": "Primary action. Live state. Single signature color — use sparingly." },
      "accent-deep": { "value": "#0c52c2", "use": "Pressed / dark variant of accent." },
      "accent-soft": { "value": "#cfe0ff", "use": "Tinted backgrounds for highlights." }
    },
    "semantic": {
      "good": { "value": "#1a8459", "use": "Success, completed, savings." },
      "warn": { "value": "#c8841a", "use": "Warning, awaiting action." },
      "hot":  { "value": "#d94545", "use": "Danger, canceled, rejection." }
    },
    "on-color": {
      "on-ink":    { "value": "#f3f7f4" },
      "on-accent": { "value": "#ffffff" }
    }
  },
  "type": {
    "families": {
      "display": { "value": "Space Grotesk", "weights": [400, 500, 700], "source": "Google Fonts" },
      "ui":      { "value": "Space Grotesk", "weights": [400, 500, 700], "source": "Google Fonts" },
      "mono":    { "value": "IBM Plex Mono", "weights": [400, 500],      "source": "Google Fonts" }
    },
    "scale": {
      "hero":    { "size": "120px", "line": 0.9,  "tracking": "-0.03em", "weight": 700, "use": "Home-screen price numeral, splash totals." },
      "display": { "size": "42px",  "line": 1.05, "tracking": "-0.01em", "weight": 700, "use": "Screen titles." },
      "h1":      { "size": "28px",  "line": 1.1,                          "weight": 700 },
      "h2":      { "size": "22px",  "line": 1.15,                         "weight": 500 },
      "body":    { "size": "15px",  "line": 1.45,                         "weight": 400 },
      "sm":      { "size": "13px",  "line": 1.4,                          "weight": 400 },
      "label":   { "size": "10px",  "line": 1.2,  "tracking": "0.14em",  "weight": 500, "use": "Mono labels, eyebrows, codes — always UPPERCASE." }
    }
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "7": "32px", "8": "48px", "9": "64px"
  },
  "radius": {
    "sq":    "2px",
    "card":  "4px",
    "sheet": "12px",
    "pill":  "9999px"
  },
  "border": { "hair": "1px", "rule": "1.5px", "bold": "2px" },
  "shadow": {
    "card":  "0 1px 0 rgba(14,34,54,0.04)",
    "sheet": "0 -2px 0 rgba(14,34,54,0.04), 0 24px 40px -20px rgba(14,34,54,0.25)",
    "focus": "0 0 0 3px rgba(25,118,255,0.25)"
  },
  "motion": {
    "ease-out": "cubic-bezier(0.2, 0.7, 0.2, 1)",
    "fast":     "120ms",
    "base":     "240ms",
    "slow":     "420ms"
  },
  "components": {
    "button": {
      "padding": "14px 20px",
      "radius":  "9999px",
      "variants": {
        "primary": { "bg": "ink",    "fg": "on-ink",    "use": "Main CTA — Confirm, Continue." },
        "accent":  { "bg": "accent", "fg": "on-accent", "use": "Live / live-tracking actions, subscription opt-in." },
        "ghost":   { "bg": "transparent", "fg": "ink",  "border": "1.5px line", "use": "Secondary actions, dismiss." }
      }
    },
    "card":   { "bg": "bg-soft", "border": "1px line", "radius": "4px", "padding": "20px" },
    "pill":   { "bg": "transparent", "border": "1px currentColor", "radius": "2px", "tone": "uses currentColor — set color on the element" },
    "input":  { "bg": "paper", "border": "1.5px line", "radius": "4px", "padding": "12px 14px" }
  },
  "voice": {
    "tone": ["plain-spoken", "confident", "minimal", "wry"],
    "do":   ["Use short verbs (Wash · Book · Track).", "Lead with the number (price, ETA, count).", "Set context with mono labels — №, EST., FIG.", "Keep marketing copy editorial, not salesy."],
    "dont": ["Don't use emoji.", "Don't exclaim. No 'woohoo'.", "Don't pad with adjectives.", "Don't use 'ASAP', 'amazing', 'game-changing'."],
    "examples": {
      "good":  ["Your washer is on the way.", "12 min · Marina Heights, Tower 2.", "Done. Looking sharp."],
      "avoid": ["🚗 Hey there! Your awesome washer is zooming over!"]
    }
  },
  "patterns": {
    "labels":   "Mono labels are always UPPERCASE with 0.14em tracking. Pair every section heading with a 2-digit index (01, 02, …) and an optional right-aligned hint.",
    "numerals": "Hero, total, ETA, count → always set in display weight at the largest scale that fits. Numbers carry the page.",
    "receipt":  "Use dotted dividers between groups in summaries and receipts to evoke a paper docket.",
    "imagery":  "Photography is direct, single-subject, daylight or magic-hour. Caption every figure: FIG. 01 — VELAR, NIGHT WASH. Never decorative SVG illustrations.",
    "icons":    "Avoid icon-led UI. Prefer mono single-letter glyphs in tabs (B, O, G, M). Use line-only icons where unavoidable; never duotone."
  }
}
