{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "convex/_generated/api": ["./convex/_generated/api.d.ts"],
      "convex/_generated/server": ["./convex/_generated/server.d.ts"],
      "convex/_generated/dataModel": ["./convex/_generated/dataModel.d.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
